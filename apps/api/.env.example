DJANGO_SECRET_KEY=replace-me-with-a-long-random-string

DB_NAME=zenapi
DB_USER=zen
DB_PASSWORD=zen
DB_HOST=localhost
DB_PORT=5432

# Service token used by email-py for service-to-service calls.
# Must match the value email-py sends in `X-Service-Token`.
SERVICE_TOKEN=dev-service-token-change-me

# CORS origin for the local UI (Next.js dev server)
UI_URL=http://localhost:3000
