# Jill — environment configuration
# Copy this file to `.env` (which is git-ignored) and fill in any secrets.
# Everything here has a sensible default, so the app runs with an empty .env in
# mock mode. You only NEED to set keys to run in `live` mode.

# ── Mode ───────────────────────────────────────────────────────────────────
# mock (default): fixtures + deterministic judges, zero secrets, no scraping.
# live: real Claude scoring/drafting and (if BRIGHTDATA_API_KEY is set) real
#       LinkedIn data.
JILL_MODE=mock

# ── Secrets (required only when JILL_MODE=live) ─────────────────────────────
# Anthropic API key — enables live Claude fit-scoring + outreach drafting.
# Get one at https://console.anthropic.com → API Keys.
ANTHROPIC_API_KEY=

# Brightdata API key — enables real LinkedIn scraping. Optional: leaving it
# blank keeps LinkedIn data mocked (recommended for a demo — real scraping is
# slow, costs money, and must respect LinkedIn's terms).
BRIGHTDATA_API_KEY=

# Extra re-scrapes when a profile comes back a "stub" (name + company only, no
# experience/about — LinkedIn's authwall blocked it). Default 1. Set 0 to skip
# blocked profiles immediately, or higher to fight transient blocks harder.
BRIGHTDATA_STUB_RETRIES=1

# ── Shared secret (the worker and the API must agree) ───────────────────────
SERVICE_TOKEN=dev-service-token-change-me

# ── Django ──────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=dev-secret-do-not-use-in-prod
DJANGO_DEBUG=1

# ── Database (defaults match apps/api/docker-compose.yml) ───────────────────
DB_NAME=zenapi
DB_USER=zen
DB_PASSWORD=zen
DB_HOST=localhost
DB_PORT=5432

# ── Worker / CLI ────────────────────────────────────────────────────────────
WEBPY_BASE_URL=http://localhost:8000
TEMPORAL_ADDRESS=localhost:7233
JILL_TENANT_ID=1

# ── Model tiers (optional overrides) ────────────────────────────────────────
JILL_SCORER_MODEL=claude-sonnet-4-6
JILL_DRAFTER_MODEL=claude-sonnet-4-6
JILL_TRIAGE_MODEL=claude-haiku-4-5
